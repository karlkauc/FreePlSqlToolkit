<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox fx:id="root" prefWidth="44" minWidth="44" maxWidth="44"
      styleClass="activity-bar" alignment="TOP_CENTER" spacing="2"
      xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.fxt.freeplsql.app.ui.shell.ActivityBarController">

    <Button fx:id="btnConnections" styleClass="activity-button" focusTraversable="false">
        <graphic><FontIcon iconLiteral="fth-database" iconSize="20"/></graphic>
    </Button>
    <Button fx:id="btnSchema" styleClass="activity-button" focusTraversable="false">
        <graphic><FontIcon iconLiteral="fth-folder" iconSize="20"/></graphic>
    </Button>
    <Button fx:id="btnFiles" styleClass="activity-button" focusTraversable="false">
        <graphic><FontIcon iconLiteral="fth-hard-drive" iconSize="20"/></graphic>
    </Button>
    <Button fx:id="btnSearch" styleClass="activity-button" focusTraversable="false">
        <graphic><FontIcon iconLiteral="fth-search" iconSize="20"/></graphic>
    </Button>
    <Button fx:id="btnMetrics" styleClass="activity-button" focusTraversable="false">
        <graphic><FontIcon iconLiteral="fth-bar-chart-2" iconSize="20"/></graphic>
    </Button>
    <Button fx:id="btnInvalid" styleClass="activity-button" focusTraversable="false">
        <graphic><FontIcon iconLiteral="fth-alert-octagon" iconSize="20"/></graphic>
    </Button>
    <Button fx:id="btnDiff" styleClass="activity-button" focusTraversable="false">
        <graphic><FontIcon iconLiteral="fth-git-pull-request" iconSize="20"/></graphic>
    </Button>

    <Region VBox.vgrow="ALWAYS"/>

    <Button fx:id="btnTheme" styleClass="activity-button" focusTraversable="false">
        <graphic><FontIcon fx:id="themeIcon" iconLiteral="fth-moon" iconSize="20"/></graphic>
    </Button>
</VBox>
